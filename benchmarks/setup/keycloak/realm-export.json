{
  "realm": "benchmark",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "user",
        "composite": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "bench-client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "bench-secret-12345678",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email"],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "service-account-bench-client",
      "enabled": true,
      "serviceAccountClientId": "bench-client",
      "realmRoles": ["user"]
    }
  ]
}
