{
  "openapi": "3.1.0",
  "info": {
    "title": "OAuth2 Server API",
    "description": "A complete OAuth2 server implementation with Actix-web, featuring social logins and OIDC support",
    "contact": {
      "name": "API Support",
      "email": "support@example.com"
    },
    "license": {
      "name": "MIT OR Apache-2.0"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/.well-known/jwks.json": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "JSON Web Key Set",
        "description": "Returns the public keys used to verify tokens issued by this server.",
        "operationId": "jwks_stub",
        "responses": {
          "200": {
            "description": "JWKS document"
          }
        }
      }
    },
    "/.well-known/openid-configuration": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "OIDC Discovery document",
        "description": "Returns server metadata: supported endpoints, grant types, algorithms, etc.",
        "operationId": "openid_configuration_stub",
        "responses": {
          "200": {
            "description": "OIDC Provider Metadata"
          }
        }
      }
    },
    "/admin/clients/register": {
      "post": {
        "tags": [
          "Client Management"
        ],
        "summary": "Register a new client",
        "description": "Registers a new OAuth2 client application. Requires admin session.",
        "operationId": "register_client_stub",
        "requestBody": {
          "description": "Client registration metadata",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientRegistration"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Client registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientCredentials"
                }
              }
            }
          },
          "400": {
            "description": "Invalid registration request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Liveness probe",
        "description": "Returns 200 OK when the server process is running.",
        "operationId": "health_stub",
        "responses": {
          "200": {
            "description": "Server is alive"
          }
        }
      }
    },
    "/oauth/authorize": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Authorization endpoint",
        "description": "Initiates the Authorization Code flow. On success, redirects to the registered `redirect_uri` with an authorization code.",
        "operationId": "authorize_stub",
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "description": "Must be `code`",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "description": "Registered client identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "description": "Registered redirect URI",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "description": "Space-separated list of requested scopes",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Opaque value used to maintain state between request and callback",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nonce",
            "in": "query",
            "description": "OIDC nonce – bound into the id_token",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge",
            "in": "query",
            "description": "PKCE code challenge (RFC 7636)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge_method",
            "in": "query",
            "description": "PKCE method: `S256` or `plain`",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to redirect_uri with `code` parameter"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized – user not authenticated"
          }
        }
      }
    },
    "/oauth/device_authorization": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Device authorization endpoint",
        "description": "Initiates the Device Authorization Grant. Returns `device_code`, `user_code`, `verification_uri`, and `interval`.",
        "operationId": "device_authorization_stub",
        "requestBody": {
          "description": "`client_id` and optional `scope`",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Device authorization response"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/introspect": {
      "post": {
        "tags": [
          "Token Management"
        ],
        "summary": "Token introspection",
        "description": "Returns metadata about an access or refresh token. Requires client authentication.",
        "operationId": "introspect_stub",
        "requestBody": {
          "description": "Form field `token` containing the token to introspect; optional `token_type_hint`",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Introspection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntrospectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          },
          "401": {
            "description": "Client authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "client_secret_basic": []
          },
          {
            "client_secret_post": []
          }
        ]
      }
    },
    "/oauth/logout": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "OIDC RP-Initiated Logout",
        "description": "Terminates the user's local session. If `post_logout_redirect_uri` is provided and matches a registered redirect URI, redirects there after logout.",
        "operationId": "logout_stub",
        "parameters": [
          {
            "name": "id_token_hint",
            "in": "query",
            "description": "Previously issued ID token; used to identify the session/client",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "post_logout_redirect_uri",
            "in": "query",
            "description": "URI to redirect to after logout; must match a registered redirect URI",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Opaque state value passed back on redirect",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session terminated; no redirect requested"
          },
          "302": {
            "description": "Redirect to post_logout_redirect_uri"
          },
          "400": {
            "description": "Invalid or unregistered post_logout_redirect_uri",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/revoke": {
      "post": {
        "tags": [
          "Token Management"
        ],
        "summary": "Token revocation",
        "description": "Revokes an access or refresh token. Requires client authentication.",
        "operationId": "revoke_stub",
        "requestBody": {
          "description": "Form field `token` to revoke; optional `token_type_hint`",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Token revoked (or already invalid; per RFC 7009 always 200)"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          },
          "401": {
            "description": "Client authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "client_secret_basic": []
          },
          {
            "client_secret_post": []
          }
        ]
      }
    },
    "/oauth/token": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Token endpoint",
        "description": "Issues access tokens.  Accepts `application/x-www-form-urlencoded` bodies.",
        "operationId": "token_stub",
        "requestBody": {
          "description": "Token request parameters",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "access_token",
                  "token_type",
                  "expires_in"
                ],
                "properties": {
                  "access_token": {
                    "type": "string"
                  },
                  "expires_in": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "id_token": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "OIDC id_token – present when the `openid` scope was requested."
                  },
                  "refresh_token": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "scope": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "token_type": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          },
          "401": {
            "description": "Client authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/userinfo": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "OIDC UserInfo endpoint",
        "description": "Returns claims about the authenticated user. Requires a Bearer access token with the `openid` scope.",
        "operationId": "userinfo_stub",
        "responses": {
          "200": {
            "description": "UserInfo claims as JSON"
          },
          "401": {
            "description": "Missing or invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": [
              "openid"
            ]
          }
        ]
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Readiness probe",
        "description": "Returns 200 OK when the server is ready to accept traffic (database connection healthy).",
        "operationId": "readiness_stub",
        "responses": {
          "200": {
            "description": "Server is ready"
          },
          "503": {
            "description": "Not ready – storage unavailable"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClientCredentials": {
        "type": "object",
        "required": [
          "client_id",
          "client_secret"
        ],
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          }
        }
      },
      "ClientRegistration": {
        "type": "object",
        "required": [
          "client_name",
          "redirect_uris",
          "grant_types",
          "scope"
        ],
        "properties": {
          "client_name": {
            "type": "string"
          },
          "grant_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "redirect_uris": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "IntrospectionResponse": {
        "type": "object",
        "required": [
          "active"
        ],
        "properties": {
          "active": {
            "type": "boolean"
          },
          "client_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "exp": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "iat": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "scope": {
            "type": [
              "string",
              "null"
            ]
          },
          "sub": {
            "type": [
              "string",
              "null"
            ]
          },
          "token_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "username": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "OAuth2Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "error_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "error_uri": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "required": [
          "access_token",
          "token_type",
          "expires_in"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "format": "int32"
          },
          "id_token": {
            "type": [
              "string",
              "null"
            ],
            "description": "OIDC id_token – present when the `openid` scope was requested."
          },
          "refresh_token": {
            "type": [
              "string",
              "null"
            ]
          },
          "scope": {
            "type": [
              "string",
              "null"
            ]
          },
          "token_type": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "OAuth2",
      "description": "OAuth2 authentication and authorization endpoints"
    },
    {
      "name": "Client Management",
      "description": "Client registration and management"
    },
    {
      "name": "Token Management",
      "description": "Token introspection and revocation"
    },
    {
      "name": "Admin",
      "description": "Administrative and monitoring endpoints"
    },
    {
      "name": "Observability",
      "description": "Health checks and metrics"
    }
  ]
}