# Copy to `.env` for local development.
# The canonical runtime contract lives in this file and `application.conf.example`.

# Server
OAUTH2_SERVER_HOST=127.0.0.1
OAUTH2_SERVER_PORT=8080
# Optional explicit Actix worker count.
OAUTH2_SERVER_WORKERS=
# Externally visible URL used in OIDC discovery docs behind a proxy or tunnel.
# Alias accepted by the runtime: OAUTH2_PUBLIC_URL
OAUTH2_SERVER_PUBLIC_BASE_URL=
# Trust Forwarded / X-Forwarded-* headers only when running behind a trusted proxy.
OAUTH2_SERVER_TRUST_PROXY_HEADERS=false

# Storage backend selection (URL scheme decides backend)
# - SQLite (default): sqlite:oauth2.db
# - PostgreSQL:       postgresql://user:pass@localhost:5432/oauth2
# - MongoDB:          mongodb://localhost:27017/oauth2   (requires: --features mongo)
OAUTH2_DATABASE_URL=sqlite:oauth2.db

# Optional read replica for geographically local read traffic.
OAUTH2_DATABASE_READ_URL=

# Database pool tuning.
OAUTH2_DATABASE_MAX_CONNECTIONS=50
OAUTH2_DATABASE_MIN_CONNECTIONS=1
OAUTH2_DATABASE_ACQUIRE_TIMEOUT_SECS=30
OAUTH2_DATABASE_IDLE_TIMEOUT_SECS=600

# Security and seed admin user
# Must be >= 32 chars. Use a random value in real deployments.
OAUTH2_JWT_SECRET=replace-with-a-random-32+-char-secret
# Must be 128 hex characters (64 bytes). Generate with: openssl rand -hex 64
OAUTH2_SESSION_KEY=replace-with-128-hex-characters
OAUTH2_SEED_USERNAME=admin
OAUTH2_SEED_EMAIL=admin@example.com
OAUTH2_SEED_PASSWORD=replace-with-a-local-admin-password
# JWT-only introspection (higher throughput, eventual revocation consistency).
OAUTH2_JWT_STATELESS_VALIDATION=false
# Allow unauthenticated callers to use POST /oauth/introspect.
# Default: false (recommended). Set true only for deployments that
# intentionally expose public introspection.
OAUTH2_PUBLIC_INTROSPECTION=false
# Development-only escape hatch. Never set in production.
# OAUTH2_ALLOW_INSECURE_DEFAULTS=1

# CORS
# Leave empty to deny all cross-origin requests (fail-closed).
# Example: https://app.example.com,https://admin.example.com
OAUTH2_ALLOWED_ORIGINS=

# OIDC signing (optional). If a private key is present, RS256 becomes the default.
# `OAUTH2_ID_TOKEN_PRIVATE_KEY_PEM` may contain literal newlines or \n escapes.
OAUTH2_ID_TOKEN_PRIVATE_KEY_PEM=
OAUTH2_ID_TOKEN_KID=
OAUTH2_ID_TOKEN_ALG=

# Social login (implemented today)
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback/google

# Microsoft login is also used by the `/auth/login/azure` alias.
OAUTH2_MICROSOFT_CLIENT_ID=
OAUTH2_MICROSOFT_CLIENT_SECRET=
OAUTH2_MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/callback/microsoft
OAUTH2_MICROSOFT_TENANT_ID=common

# Optional dedicated Azure config. If unset, `/auth/login/azure` falls back to the Microsoft settings above.
OAUTH2_AZURE_CLIENT_ID=
OAUTH2_AZURE_CLIENT_SECRET=
OAUTH2_AZURE_REDIRECT_URI=http://localhost:8080/auth/callback/azure
OAUTH2_AZURE_TENANT_ID=common

OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_GITHUB_REDIRECT_URI=http://localhost:8080/auth/callback/github

# Config keys exist, but these routes currently return HTTP 503.
# OAUTH2_OKTA_CLIENT_ID=
# OAUTH2_OKTA_CLIENT_SECRET=
# OAUTH2_OKTA_REDIRECT_URI=http://localhost:8080/auth/callback/okta
# OAUTH2_OKTA_DOMAIN=
# OAUTH2_AUTH0_CLIENT_ID=
# OAUTH2_AUTH0_CLIENT_SECRET=
# OAUTH2_AUTH0_REDIRECT_URI=http://localhost:8080/auth/callback/auth0
# OAUTH2_AUTH0_DOMAIN=

# Distributed cache / sharding (requires: --features redis-cache)
OAUTH2_CACHE_REDIS_URL=
# Per-instance token actor shard count. Start with 1 locally, 4+ in busy clusters.
OAUTH2_TOKEN_ACTOR_SHARDS=1

# Shared rate limiting across replicas (requires: --features redis-rate-limit)
OAUTH2_RATE_LIMIT_ENABLED=false
OAUTH2_RATE_LIMIT_BACKEND=in_memory
OAUTH2_RATE_LIMIT_REDIS_URL=
OAUTH2_RATE_LIMIT_MAX_REQUESTS=100
OAUTH2_RATE_LIMIT_WINDOW_SECS=60

# Resilience middleware
OAUTH2_RESILIENCE_ENABLED=false
OAUTH2_RESILIENCE_BP_ENABLED=true
OAUTH2_RESILIENCE_MAX_CONCURRENT=1000
OAUTH2_RESILIENCE_CB_ENABLED=true
OAUTH2_RESILIENCE_CB_FAILURE_THRESHOLD=5
OAUTH2_RESILIENCE_CB_SUCCESS_THRESHOLD=2
OAUTH2_RESILIENCE_CB_OPEN_SECS=30
OAUTH2_RESILIENCE_CB_HALF_OPEN_MAX_PROBES=3

# Observability
# Prometheus is scraped from /metrics. Tracing requires the `otel` cargo feature
# (see docs/observability.md).

# --- OpenTelemetry (optional; requires `otel` cargo feature) ---
# Collector endpoint. Empty = telemetry disabled (JSON logs only).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Legacy alias, still honored. Prefer the standard name above.
OAUTH2_OTLP_ENDPOINT=
# grpc (default) or http/protobuf. Use grpc to the in-cluster collector.
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# service.name resource attribute. Falls back to oauth2_server.
OTEL_SERVICE_NAME=oauth2_server
# W3C propagators. Keep tracecontext + baggage.
OTEL_PROPAGATORS=tracecontext,baggage
# Sampling — tail sampling happens at the collector.
OTEL_TRACES_SAMPLER=parentbased_always_on
# Kubernetes-provided pod/deployment metadata (wired via Downward API in prod).
POD_NAMESPACE=
IMAGE_SHA=
DEPLOYMENT_ENVIRONMENT=dev

# Logging
RUST_LOG=info

# Eventing
# Backends:
# - in_memory (default)
# - console
# - both
# - redis / redis_streams (requires: --features events-redis)
# - kafka (requires: --features events-kafka)
# - rabbit / rabbitmq (requires: --features events-rabbit)
OAUTH2_EVENTS_ENABLED=true
OAUTH2_EVENTS_BACKEND=in_memory

# Allow unauthenticated callers to POST to /events/ingest.
# Default: false (recommended). When false, callers must present the shared
# bearer token below.
OAUTH2_EVENTS_PUBLIC_INGEST=false
# Shared bearer token for /events/ingest when public_ingest=false.
# Example caller header: Authorization: Bearer <token>
OAUTH2_EVENTS_INGEST_BEARER_TOKEN=

# Filtering
# - allow_all (default)
# - include
# - exclude
OAUTH2_EVENTS_FILTER_MODE=allow_all
# Comma-separated list of event types (only used for include/exclude)
OAUTH2_EVENTS_TYPES=

# Redis Streams backend settings
OAUTH2_EVENTS_REDIS_URL=redis://127.0.0.1:6379
OAUTH2_EVENTS_REDIS_STREAM=oauth2_events
# Approximate MAXLEN (~). Leave blank for unlimited.
OAUTH2_EVENTS_REDIS_MAXLEN=

# Kafka backend settings
OAUTH2_EVENTS_KAFKA_BROKERS=127.0.0.1:9092
OAUTH2_EVENTS_KAFKA_TOPIC=oauth2_events
OAUTH2_EVENTS_KAFKA_CLIENT_ID=

# RabbitMQ backend settings
OAUTH2_EVENTS_RABBIT_URL=amqp://127.0.0.1:5672/%2f
OAUTH2_EVENTS_RABBIT_EXCHANGE=oauth2.events
OAUTH2_EVENTS_RABBIT_ROUTING_KEY=oauth2.event
